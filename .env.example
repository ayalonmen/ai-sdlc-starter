# Per-user credentials for this project's AI-SDLC MCP servers (in mcp.json).
# Copy this file to `.env` in this pipeline repo root and fill in your OWN values.
# `.env` is gitignored — never commit real credentials.
#
# The pipeline loads this repo's `.env` into its environment before spawning
# agents, so ${VAR} placeholders in mcp.json resolve from these values.

# MongoDB connection string used by mongodb-mcp-server (read-only recommended).
# Example: mongodb+srv://<user>:<pass>@<cluster>/<db>?readPreference=secondary
MONGODB_URI=
