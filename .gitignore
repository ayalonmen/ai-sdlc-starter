node_modules/
*.log
.env
.claude/settings.local.json

# Per-run pipeline artifacts + telemetry. Generated when the pipeline runs
# against a product (tickets and every agent's output), so they belong to a
# run, not to this fork-per-project template. events.jsonl is the live UI
# telemetry stream; runlog.jsonl is intentionally NOT ignored (it's the durable
# resume state the orchestrator reads on restart).
#
# tickets/ is kept in the repo (via .gitkeep) so the folder always exists for
# you to drop a request into — but the ticket files themselves stay ignored.
/tickets/*
!/tickets/.gitkeep
/specs/
/reviews/
/qa/
/retros/
/curator/
/events.jsonl
